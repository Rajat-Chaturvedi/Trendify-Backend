# =============================================================================
# Trendify Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/trendify?schema=public

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------

# Redis connection string used for caching and rate limiting.
# Format: redis://[:PASSWORD@]HOST:PORT[/DB_NUMBER]
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT RS256 Key Pair (REQUIRED)
# -----------------------------------------------------------------------------
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM content (with literal \n for newlines) or use a secrets manager.

# RS256 private key in PEM format (used to sign access tokens).
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# RS256 public key in PEM format (used to verify access tokens).
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# CMS Webhook (REQUIRED)
# -----------------------------------------------------------------------------

# Shared HMAC-SHA256 secret used to validate incoming Strapi webhook requests.
# Generate with: openssl rand -hex 32
STRAPI_WEBHOOK_SECRET=change-me-to-a-random-secret

# URL that the Strapi CMS posts webhook events to (the Express API webhook endpoint).
# In local development this is typically http://localhost:3000/webhooks/strapi
WEBHOOK_URL=http://localhost:3000/webhooks/strapi

# -----------------------------------------------------------------------------
# CORS (REQUIRED)
# -----------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# Example for local development: http://localhost:8081,http://localhost:19006
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# -----------------------------------------------------------------------------
# Server (OPTIONAL)
# -----------------------------------------------------------------------------

# Port the Express API server listens on. Defaults to 3000.
PORT=3000

# Application environment. One of: development, test, production. Defaults to development.
NODE_ENV=development
